# LLM Providers
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
META_LLAMA_API_KEY=your_meta_llama_api_key_here

# Obsidian Vault Context (optional)
# Path to your Obsidian vault root directory
# When set, the chat system will inject client context from 1-PROJECTS/{clientSlug}/ folders
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
